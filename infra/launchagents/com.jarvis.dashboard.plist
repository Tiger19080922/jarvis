    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/Users/bharukashiv/jarvis/logs/dashboard.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/bharukashiv/jarvis/logs/dashboard.log</string>
</dict>
</plist>
